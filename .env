# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX).
# A GA Measurement ID is public (visible in page source), so it is safe to commit.
# This is committed so git-based builds (Vercel/Netlify/etc.) include it.
# Analytics only fires on the live domain, never on localhost.
VITE_GA_MEASUREMENT_ID=G-ELSVMVNQ6J
